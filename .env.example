# Database
DB_HOST=localhost
DB_NAME=abdu_mart
DB_USER=root
DB_PASS=

# App
APP_URL=http://localhost
APP_NAME="Abdu Mart Curb Side Pickup"
APP_ENV=development
APP_KEY=change-this-to-a-long-random-secret

# Stripe (can also be set in Admin → Settings)
STRIPE_SECRET_KEY=sk_test_your_key_here
STRIPE_PUBLISHABLE_KEY=pk_test_your_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Clover POS (can also be set in Admin → Settings)
CLOVER_MERCHANT_ID=your_merchant_id
CLOVER_API_TOKEN=your_api_token
CLOVER_ENV=sandbox

# Gmail SMTP (can also be set in Admin → Settings)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=yourstore@gmail.com
SMTP_PASSWORD=your_gmail_app_password
SMTP_FROM_EMAIL=yourstore@gmail.com
SMTP_FROM_NAME="Abdu Mart"

# Google OAuth (can also be set in Admin → Settings)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Mart details
MART_ADDRESS="123 Main St, Michigan"
MART_PHONE="(555) 123-4567"
MART_PICKUP_INSTRUCTIONS="Pull up to the curb-side pickup lane. We will bring your order out."
