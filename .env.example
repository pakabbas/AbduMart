DB_PASS=

# App
APP_URL=http://localhost
APP_NAME="Abdu Mart's Curb Side Pickup"
APP_ENV=development

# Stripe (https://dashboard.stripe.com/apikeys)
STRIPE_SECRET_KEY=sk_test_your_key_here
STRIPE_PUBLISHABLE_KEY=pk_test_your_key_here
