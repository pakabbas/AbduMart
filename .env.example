# Database
DB_HOST=localhost
DB_NAME=abdu_mart
DB_USER=root
DB_PASS=

# App
APP_URL=http://localhost
APP_NAME="Abdu Market Curb Side Pickup"
APP_ENV=development
APP_KEY=change-this-to-a-long-random-secret

# Stripe (can also be set in Admin → Settings)
STRIPE_SECRET_KEY=sk_test_your_key_here
STRIPE_PUBLISHABLE_KEY=pk_test_your_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Clover POS + Hosted Checkout (can also be set in Admin → Settings)
CLOVER_MERCHANT_ID=your_merchant_id
CLOVER_API_TOKEN=your_api_token
CLOVER_ENV=sandbox
CLOVER_WEBHOOK_SECRET=hcp_your_hosted_checkout_signing_secret

# Gmail SMTP (can also be set in Admin → Settings)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=yourstore@gmail.com
SMTP_PASSWORD=your_gmail_app_password
SMTP_FROM_EMAIL=yourstore@gmail.com
SMTP_FROM_NAME="Abdu Market"

# Google OAuth (can also be set in Admin → Settings)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Mart details
MART_ADDRESS="46090 Michigan Ave, Canton Township, MI 48188, United States"
MART_PHONE="+1 734-322-9240"
MART_PICKUP_INSTRUCTIONS="Pull up to the curb-side pickup lane at Abdu Market. Tap I'm Here when you arrive and we will bring your order out."
